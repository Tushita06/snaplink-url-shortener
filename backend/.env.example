# SnapLink Backend Configuration

# Server Port
PORT=5000

# MongoDB URI (Local or Atlas Cloud Connection string)
MONGODB_URI=mongodb://127.0.0.1:27017/snaplink

# JWT Authentication Config
JWT_SECRET=your_jwt_signing_secret_here
JWT_EXPIRE=30d

# Frontend Application URL (for redirection handling e.g. /expired or /not-found)
FRONTEND_URL=http://localhost:5173

# Application Environment Mode (development / production)
NODE_ENV=development

# Nodemailer Gmail Config (use a Gmail App Password, not your real password)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
